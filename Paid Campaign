    // ================================================================
    const usersRef = database.ref('users');
    const depositsRef = database.ref('deposits');
    const campaignsRef = database.ref('campaigns');
    const settingsRef = database.ref('settings');

    // ================================================================
    // STATE
    // ================================================================
    let isLoggedIn = false;
    let currentUser = {
        id: null,
        username: '',
        phone: '',
        balance: 0,
        status: 'active'
    };

    let selectedBudget = null;
    let settingsData = {};
    
    // ================================================================
    // FLAG untuk mencegah double submit
    // ================================================================
    let isDepositSubmitting = false;
    let isCampaignSubmitting = false;

    // ================================================================
    // TOAST NOTIFICATION
    // ================================================================
    function showToast(message, type = 'success') {
        const existing = document.querySelector('.toast');
        if (existing) existing.remove();

        const toast = document.createElement('div');
        toast.className = `toast toast-${type}`;
        toast.textContent = message;
        document.body.appendChild(toast);

        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transition = 'opacity 0.3s';
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    }

    // ================================================================
    // FORMATTING
    // ================================================================
    function formatMoney(amount) {
        return '৳' + Number(amount).toFixed(2);
    }

    // ================================================================
    // CONNECTION STATUS
    // ================================================================
    function updateConnectionStatus(connected) {
        const statusEl = document.getElementById('connectionStatus');
        const dot = document.querySelector('.dot');
        if (connected) {
            statusEl.textContent = 'Connected';
            dot.style.background = '#4ade80';
        } else {
            statusEl.textContent = 'Disconnected';
            dot.style.background = '#f87171';
        }
    }

    database.ref('.info/connected').on('value', (snap) => {
        updateConnectionStatus(snap.val());
    });

    // ================================================================
    // RENDER FUNCTIONS
    // ================================================================
    function updateAllBalances() {
        const bal = formatMoney(currentUser.balance || 0);
        document.getElementById('dashBalance').textContent = bal;
        document.getElementById('dashTotalAssets').textContent = bal;
        document.getElementById('depositBalance').textContent = bal;
        document.getElementById('campaignBalance').textContent = bal;
        document.getElementById('myCampaignsBalance').textContent = bal;
        document.getElementById('supportBalance').textContent = bal;
    }

    function renderCampaignsTable(campaigns) {
        const tbody = document.getElementById('campaignsTableBody');
        const userCampaigns = campaigns.filter(c => c.userId === currentUser.id);
        
        if (userCampaigns.length === 0) {
            tbody.innerHTML = `<tr><td colspan="3" style="text-align:center; color:#6b7f94; padding:30px 0;">No campaigns yet. Create your first campaign!</td></tr>`;
            return;
        }
        tbody.innerHTML = userCampaigns.map(c => `
            <tr>
                <td>৳${c.budget}</td>
                <td>${c.date || 'N/A'}</td>
                <td class="${c.status === 'completed' ? 'status-completed' : c.status === 'pending' ? 'status-pending' : 'status-rejected'}">${c.status.charAt(0).toUpperCase() + c.status.slice(1)}</td>
            </tr>
        `).join('');
    }

    function renderTargetUrls(campaigns) {
        const container = document.getElementById('targetUrlList');
        const userCampaigns = campaigns.filter(c => c.userId === currentUser.id);
        const urls = userCampaigns.map(c => c.targetUrl).filter(url => url);
        
        if (urls.length === 0) {
            container.innerHTML = `
                <div class="empty-state">
                    <i class="fas fa-link"></i>
                    <h3>No URLs Added</h3>
                    <p>Your campaign target URLs will appear here</p>
                </div>
            `;
            return;
        }
        container.innerHTML = urls.map(url => `
            <div class="url-item">
                <span class="check">☐</span>
                <span>${url}</span>
            </div>
        `).join('');
    }

    function renderDepositHistory(deposits) {
        const tbody = document.getElementById('depositHistoryBody');
        const userDeposits = deposits.filter(d => d.userId === currentUser.id);
        
        if (userDeposits.length === 0) {
            tbody.innerHTML = `<tr><td colspan="4" style="text-align:center; color:#6b7f94; padding:30px 0;">No deposit history yet</td></tr>`;
            return;
        }
        tbody.innerHTML = userDeposits.map(d => `
            <tr>
                <td>${d.method || 'N/A'}</td>
                <td>${d.trxid || 'N/A'}</td>
                <td>৳${Number(d.amount).toFixed(2)}</td>
                <td class="${d.status === 'approved' ? 'status-approved' : d.status === 'pending' ? 'status-pending' : 'status-rejected'}">${d.status.charAt(0).toUpperCase() + d.status.slice(1)}</td>
            </tr>
        `).join('');
    }

    function renderStats(campaigns) {
        const userCampaigns = campaigns.filter(c => c.userId === currentUser.id);
        const pending = userCampaigns.filter(c => c.status === 'pending').length;
        const active = userCampaigns.filter(c => c.status === 'approved' || c.status === 'active').length;
        const completed = userCampaigns.filter(c => c.status === 'completed').length;
        
        document.getElementById('statPending').textContent = pending;
        document.getElementById('statActive').textContent = active;
        document.getElementById('statCompleted').textContent = completed;
    }

    function renderRules(settings) {
        const container = document.getElementById('rulesListDisplay');
        const rules = settings?.rules || ['No rules set by admin'];
        container.innerHTML = rules.map(rule => `<li>${rule}</li>`).join('');
    }

    function renderBudgets(settings) {
        const container = document.getElementById('budgetGroup');
        const budgets = settings?.budgets || [
            { amount: 30, label: 'Trial Pack' },
            { amount: 50, label: 'Starter Pack' },
            { amount: 100, label: 'Growth Pack' },
            { amount: 500, label: 'Premium Boost' }
        ];
        
        container.innerHTML = budgets.map(b => `
            <div class="budget-btn" data-budget="${b.amount}">৳${b.amount} ${b.label}</div>
        `).join('');
        
        // Re-bind budget click events - using event delegation to avoid duplicates
    }

    function renderPaymentInfo(settings) {
        const info = settings?.paymentInfo || { number: '01727369268', binanceId: '180728766', minDeposit: 50 };
        document.getElementById('displayPaymentNumber').textContent = info.number || '01727369268';
        document.getElementById('displayBinanceId').textContent = info.binanceId || '180728766';
        document.getElementById('displayMinDeposit').textContent = '৳' + (info.minDeposit || 50);
    }

    function renderPaymentMethods(settings) {
        const select = document.getElementById('paymentMethodSelect');
        const methods = settings?.paymentMethods || ['bKash Personal', 'Nagad', 'Rocket'];
        select.innerHTML = methods.map(m => `<option value="${m}">${m}</option>`).join('');
    }

    function renderUserInfo() {
        document.getElementById('dashUsername').textContent = currentUser.username || 'User';
        document.getElementById('dashPhone').textContent = '📞 ' + (currentUser.phone || '+8801XXXXXXXXX');
    }

    // ================================================================
    // FIREBASE REAL-TIME LISTENERS
    // ================================================================
    function startRealtimeListeners() {
        // Listen for settings changes
        settingsRef.on('value', (snapshot) => {
            settingsData = snapshot.val() || {};
            renderRules(settingsData);
            renderBudgets(settingsData);
            renderPaymentInfo(settingsData);
            renderPaymentMethods(settingsData);
        });

        // Listen for deposits
        depositsRef.on('value', (snapshot) => {
            const deposits = snapshot.val() || {};
            const depositArray = Object.values(deposits);
            renderDepositHistory(depositArray);
        });

        // Listen for campaigns
        campaignsRef.on('value', (snapshot) => {
            const campaigns = snapshot.val() || {};
            const campaignArray = Object.values(campaigns);
            renderCampaignsTable(campaignArray);
            renderTargetUrls(campaignArray);
            renderStats(campaignArray);
        });

        // Listen for user balance updates
        if (currentUser.id) {
            usersRef.child(currentUser.id).on('value', (snapshot) => {
                const userData = snapshot.val();
                if (userData) {
                    currentUser.balance = userData.balance || 0;
                    currentUser.status = userData.status || 'active';
                    updateAllBalances();
                }
            });
        }
    }

    function stopRealtimeListeners() {
        depositsRef.off();
        campaignsRef.off();
        settingsRef.off();
        if (currentUser.id) {
            usersRef.child(currentUser.id).off();
        }
    }

    // ================================================================
    // SIDEBAR CONTROLS
    // ================================================================
    function openSidebar() {
        document.getElementById('sidebarDrawer').classList.add('active');
        document.getElementById('sidebarOverlay').classList.add('active');
        document.body.style.overflow = 'hidden';
    }

    function closeSidebar() {
        document.getElementById('sidebarDrawer').classList.remove('active');
        document.getElementById('sidebarOverlay').classList.remove('active');
        document.body.style.overflow = '';
    }

    document.getElementById('hamburgerBtn').addEventListener('click', openSidebar);
    document.getElementById('closeSidebar').addEventListener('click', closeSidebar);
    document.getElementById('sidebarOverlay').addEventListener('click', closeSidebar);

    // ================================================================
    // NAVIGATION
    // ================================================================
    function navigateTo(page) {
        document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
        const target = document.getElementById('page-' + page);
        if (target) target.classList.add('active');

        document.querySelectorAll('.drawer-nav-item[data-page]').forEach(item => {
            item.classList.remove('active');
            if (item.getAttribute('data-page') === page) {
                item.classList.add('active');
            }
        });

        closeSidebar();
    }

    document.querySelectorAll('.drawer-nav-item[data-page]').forEach(item => {
        item.addEventListener('click', () => {
            const page = item.getAttribute('data-page');
            navigateTo(page);
        });
    });

    // ================================================================
    // AUTHENTICATION
    // ================================================================
    function renderAuth() {
        const container = document.getElementById('authContainer');
        container.innerHTML = `
            <div style="background:white; border-radius:30px; padding:40px 30px; box-shadow:0 10px 30px rgba(0,0,0,0.08);">
                <h1 style="font-size:28px; font-weight:900; color:#0a1e2f;">PAID CAMPAIGN</h1>
                <p style="color:#6b7f94; margin-bottom:28px;">Sign in to manage your campaigns</p>

                <div class="form-group">
                    <label>Phone Number</label>
                    <input type="tel" id="loginPhone" placeholder="Enter phone number">
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" id="loginPass" placeholder="Enter password">
                </div>
                <button class="btn-primary" id="loginBtn">Sign In</button>

                <p style="text-align:center; margin-top:20px; color:#5b6e8c;">
                    Don't have an account? <a href="#" id="showSignup" style="color:#0a1e2f; font-weight:700; text-decoration:none;">Sign Up Here</a>
                </p>
            </div>
        `;

        document.getElementById('loginBtn').addEventListener('click', handleLogin);
        document.getElementById('loginPass').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') handleLogin();
        });
        document.getElementById('loginPhone').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') handleLogin();
        });

        document.getElementById('showSignup').addEventListener('click', (e) => {
            e.preventDefault();
            renderSignup();
        });
    }

    async function handleLogin() {
        const phone = document.getElementById('loginPhone').value.trim();
        const pass = document.getElementById('loginPass').value.trim();

        if (!phone || !pass) {
            showToast('Please enter phone and password', 'error');
            return;
        }

        const btn = document.getElementById('loginBtn');
        btn.disabled = true;
        btn.innerHTML = '<span class="loading-spinner"></span> Signing In...';

        try {
            const snapshot = await usersRef.orderByChild('phone').equalTo(phone).once('value');
            const users = snapshot.val();
            
            let foundUser = null;
            let userId = null;
            
            if (users) {
                for (const [key, value] of Object.entries(users)) {
                    if (value.password === pass) {
                        foundUser = value;
                        userId = key;
                        break;
                    }
                }
            }

            if (foundUser && userId) {
                if (foundUser.status === 'banned') {
                    showToast('🚫 Your account has been banned by admin!', 'error');
                    btn.disabled = false;
                    btn.innerHTML = 'Sign In';
                    return;
                }
                
                currentUser.id = userId;
                currentUser.username = foundUser.username || 'User';
                currentUser.phone = foundUser.phone;
                currentUser.balance = foundUser.balance || 0;
                currentUser.status = foundUser.status || 'active';
                
                isLoggedIn = true;
                showDashboard();
                showToast(`✅ Welcome back, ${currentUser.username}!`, 'success');
                startRealtimeListeners();
                
            } else {
                showToast('❌ Invalid phone number or password!', 'error');
            }
        } catch (error) {
            showToast('❌ Error: ' + error.message, 'error');
            console.error(error);
        }

        btn.disabled = false;
        btn.innerHTML = 'Sign In';
    }

    function renderSignup() {
        const container = document.getElementById('authContainer');
        container.innerHTML = `
            <div style="background:white; border-radius:30px; padding:40px 30px; box-shadow:0 10px 30px rgba(0,0,0,0.08);">
                <h1 style="font-size:28px; font-weight:900; color:#0a1e2f;">PAID CAMPAIGN</h1>
                <p style="color:#6b7f94; margin-bottom:28px;">Create your account</p>

                <div class="form-group">
                    <label>Username</label>
                    <input type="text" id="regUsername" placeholder="Your name">
                </div>
                <div class="form-group">
                    <label>Phone Number</label>
                    <input type="tel" id="regPhone" placeholder="Account phone number">
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" id="regPass" placeholder="Create a password">
                </div>
                <button class="btn-primary" id="signupBtn">Create Account</button>

                <p style="text-align:center; margin-top:20px; color:#5b6e8c;">
                    Already have an account? <a href="#" id="showLogin" style="color:#0a1e2f; font-weight:700; text-decoration:none;">Sign In Here</a>
                </p>
            </div>
        `;

        document.getElementById('signupBtn').addEventListener('click', handleSignup);
        document.getElementById('regPass').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') handleSignup();
        });

        document.getElementById('showLogin').addEventListener('click', (e) => {
            e.preventDefault();
            renderAuth();
        });
    }

    async function handleSignup() {
        const uname = document.getElementById('regUsername').value.trim();
        const phone = document.getElementById('regPhone').value.trim();
        const pass = document.getElementById('regPass').value.trim();

        if (!uname || !phone || !pass) {
            showToast('Please fill all fields', 'error');
            return;
        }

        const btn = document.getElementById('signupBtn');
        btn.disabled = true;
        btn.innerHTML = '<span class="loading-spinner"></span> Creating Account...';

        try {
            const snapshot = await usersRef.orderByChild('phone').equalTo(phone).once('value');
            if (snapshot.exists()) {
                showToast('❌ This phone number is already registered!', 'error');
                btn.disabled = false;
                btn.innerHTML = 'Create Account';
                return;
            }

            const newUser = {
                username: uname,
                phone: phone,
                password: pass,
                balance: 0,
                status: 'active',
                createdAt: new Date().toISOString()
            };

            const newRef = usersRef.push(newUser);
            
            currentUser.id = newRef.key;
            currentUser.username = uname;
            currentUser.phone = phone;
            currentUser.balance = 0;
            currentUser.status = 'active';
            
            isLoggedIn = true;
            showToast('✅ Account created successfully!', 'success');
            showDashboard();
            startRealtimeListeners();

        } catch (error) {
            showToast('❌ Error: ' + error.message, 'error');
            console.error(error);
        }

        btn.disabled = false;
        btn.innerHTML = 'Create Account';
    }

    // ================================================================
    // DASHBOARD SHOW
    // ================================================================
    function showDashboard() {
        document.getElementById('authView').classList.add('hidden');
        document.getElementById('dashView').classList.remove('hidden');
        renderUserInfo();
        updateAllBalances();
        navigateTo('dashboard');
    }

    // ================================================================
    // LOGOUT
    // ================================================================
    document.getElementById('logoutBtn').addEventListener('click', () => {
        stopRealtimeListeners();
        isLoggedIn = false;
        currentUser = { id: null, username: '', phone: '', balance: 0 };
        document.getElementById('dashView').classList.add('hidden');
        document.getElementById('authView').classList.remove('hidden');
        renderAuth();
        showToast('👋 Logged out successfully', 'info');
    });

    // ================================================================
    // EVENT BINDING - Using event delegation to prevent duplicates
    // ================================================================
    function setupEventListeners() {
        // ===== BUDGET BUTTONS - Using event delegation =====
        document.getElementById('budgetGroup').addEventListener('click', function(e) {
            const btn = e.target.closest('.budget-btn');
            if (!btn) return;
            
            document.querySelectorAll('.budget-btn').forEach(b => b.classList.remove('selected'));
            btn.classList.add('selected');
            selectedBudget = parseInt(btn.getAttribute('data-budget'));
        });

        // ===== LAUNCH CAMPAIGN =====
        const launchBtn = document.getElementById('launchCampaignBtn');
        // Remove any existing listeners by cloning
        const newLaunchBtn = launchBtn.cloneNode(true);
        launchBtn.parentNode.replaceChild(newLaunchBtn, launchBtn);
        
        newLaunchBtn.addEventListener('click', async function(e) {
            // Prevent double submit
            if (isCampaignSubmitting) return;
            isCampaignSubmitting = true;
            
            const url = document.getElementById('campaignUrl').value.trim();
            if (!url) { 
                showToast('Enter target URL', 'error'); 
                isCampaignSubmitting = false;
                return; 
            }
            if (!selectedBudget) { 
                showToast('Select a budget tier', 'error'); 
                isCampaignSubmitting = false;
                return; 
            }
            if (currentUser.balance < selectedBudget) {
                showToast(`Insufficient balance. Need ৳${selectedBudget}. Please deposit.`, 'error');
                isCampaignSubmitting = false;
                return;
            }

            this.disabled = true;
            this.innerHTML = '<span class="loading-spinner"></span> Submitting...';

            try {
                const newBalance = currentUser.balance - selectedBudget;
                await usersRef.child(currentUser.id).update({ balance: newBalance });
                currentUser.balance = newBalance;

                await campaignsRef.push({
                    userId: currentUser.id,
                    username: currentUser.username,
                    budget: selectedBudget,
                    targetUrl: url,
                    date: new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }),
                    status: 'pending',
                    createdAt: new Date().toISOString()
                });

                document.getElementById('campaignUrl').value = '';
                document.querySelectorAll('.budget-btn').forEach(b => b.classList.remove('selected'));
                selectedBudget = null;
                
                showToast('✅ Campaign submitted for admin review!', 'success');
                updateAllBalances();
                navigateTo('mycampaigns');

            } catch (error) {
                showToast('❌ Error: ' + error.message, 'error');
                console.error(error);
            }

            this.disabled = false;
            this.innerHTML = 'Launch Campaign Now';
            isCampaignSubmitting = false;
        });

        // ===== SUBMIT DEPOSIT =====
        const depositBtn = document.getElementById('submitDepositBtn');
        // Remove any existing listeners by cloning
        const newDepositBtn = depositBtn.cloneNode(true);
        depositBtn.parentNode.replaceChild(newDepositBtn, depositBtn);
        
        newDepositBtn.addEventListener('click', async function(e) {
            // Prevent double submit
            if (isDepositSubmitting) return;
            isDepositSubmitting = true;
            
            const mobile = document.getElementById('depositMobile').value.trim();
            const trxid = document.getElementById('depositTrxid').value.trim();
            const amount = parseFloat(document.getElementById('depositAmount').value);
            const method = document.getElementById('paymentMethodSelect').value;
            const minDeposit = settingsData?.paymentInfo?.minDeposit || 50;
            
            if (!mobile) { 
                showToast('Enter sender mobile number', 'error'); 
                isDepositSubmitting = false;
                return; 
            }
            if (!trxid) { 
                showToast('Enter transaction ID', 'error'); 
                isDepositSubmitting = false;
                return; 
            }
            if (!amount || amount < minDeposit) { 
                showToast(`Minimum deposit is ৳${minDeposit}`, 'error'); 
                isDepositSubmitting = false;
                return; 
            }

            this.disabled = true;
            this.innerHTML = '<span class="loading-spinner"></span> Submitting...';

            try {
                await depositsRef.push({
                    userId: currentUser.id,
                    username: currentUser.username,
                    method: method,
                    trxid: trxid,
                    amount: amount,
                    status: 'pending',
                    date: new Date().toLocaleDateString(),
                    createdAt: new Date().toISOString()
                });

                showToast('✅ Deposit request submitted! Admin will verify and approve.', 'success');
                document.getElementById('depositMobile').value = '';
                document.getElementById('depositTrxid').value = '';
                document.getElementById('depositAmount').value = '';

            } catch (error) {
                showToast('❌ Error: ' + error.message, 'error');
                console.error(error);
            }

            this.disabled = false;
            this.innerHTML = 'Submit Deposit Request';
            isDepositSubmitting = false;
        });
    }

    // ================================================================
    // INIT
    // ================================================================
    renderAuth();
    setupEventListeners();

    // Re-setup after navigation
    const originalNavigate = navigateTo;
    navigateTo = function(page) {
        originalNavigate(page);
        // Re-setup event listeners after DOM update
        setTimeout(setupEventListeners, 100);
    };

    console.log('✅ User Panel Loaded - Firebase Connected');
    console.log('📌 Double submit prevention enabled');
</script>

</body>
